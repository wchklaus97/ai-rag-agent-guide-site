{
  "primitive": {
    "color": {
      "cream50": "oklch(0.98 0.01 85)",
      "ink900": "oklch(0.22 0.02 260)",
      "ink600": "oklch(0.45 0.02 260)",
      "blue650": "oklch(0.5 0.12 250)",
      "white": "oklch(1 0 0)"
    },
    "space": {
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "5": "1.25rem",
      "8": "2rem",
      "12": "3rem"
    },
    "radius": {
      "sm": "0.2rem",
      "md": "0.35rem",
      "lg": "0.4rem",
      "pill": "999px"
    },
    "typography": {
      "fontSerif": "\"Literata\", Georgia, serif",
      "fontSans": "\"Atkinson Hyperlegible\", system-ui, sans-serif",
      "lineBody": "1.55",
      "lineHeading": "1.2",
      "maxRead": "72ch"
    }
  },
  "semantic": {
    "color": {
      "bg": "var(--primitive-cream-50)",
      "surface": "color-mix(in oklch, var(--color-bg) 97%, var(--primitive-white))",
      "surfaceRaised": "color-mix(in oklch, var(--color-bg) 92%, var(--primitive-white))",
      "text": "var(--primitive-ink-900)",
      "textMuted": "var(--primitive-ink-600)",
      "border": "color-mix(in oklch, var(--color-text) 18%, var(--color-bg))",
      "accent": "var(--primitive-blue-650)",
      "accentSoft": "color-mix(in oklch, var(--color-accent) 15%, var(--color-bg))"
    },
    "typography": {
      "display": "var(--primitive-font-serif)",
      "body": "var(--primitive-font-sans)",
      "readableMeasure": "var(--primitive-max-read)"
    }
  },
  "component": {
    "panel": {
      "background": "var(--color-surface)",
      "border": "var(--color-border)",
      "radius": "var(--primitive-radius-lg)",
      "shadow": "var(--shadow-hairline)"
    },
    "control": {
      "background": "var(--color-bg)",
      "text": "var(--color-text)",
      "border": "var(--color-border)",
      "activeBackground": "var(--color-accent-soft)",
      "focus": "var(--color-accent)"
    },
    "card": {
      "background": "var(--color-bg)",
      "hoverShadow": "var(--shadow-soft)"
    },
    "tag": {
      "background": "var(--color-tag-bg)",
      "radius": "var(--primitive-radius-sm)"
    }
  }
}
